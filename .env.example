# =============================================================================
# StreamHub — self-hosted LiveKit media server (OSS quick-install)
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values, OR just run ./install.sh
# which generates a `.env` with strong random secrets for you.
#
#   cp .env.example .env      # then edit
#   docker compose up -d
#
# NEVER commit the real `.env`. All *_SECRET / *_PASS / *_TOKEN values below
# must be long and random in production.
# =============================================================================

# ---------------------------------------------------------------------------
# Public identity / TLS
# ---------------------------------------------------------------------------
# The single public domain that fronts everything (Caddy reverse proxy + TLS).
#   Production: a real hostname with a DNS A record pointing at this server's
#               public IP (DNS-only, NOT proxied through Cloudflare — WebRTC
#               media is UDP and won't traverse an HTTP proxy).
#   Local test: `localhost` (Caddy serves a local self-signed cert on :443).
STREAMHUB_DOMAIN=streamhub.example.com

# Email used for Let's Encrypt / ACME registration (real domains only).
ACME_EMAIL=admin@example.com

# ---------------------------------------------------------------------------
# LiveKit — SFU keys (shared by server + ingress + egress)
# ---------------------------------------------------------------------------
# Generate with `livekit-server generate-keys`, or install.sh makes them.
# The key name conventionally starts with "API".
LIVEKIT_API_KEY=APIchangeme000000
LIVEKIT_API_SECRET=change-me-a-long-random-secret

# ---------------------------------------------------------------------------
# StreamHub core (NestJS) — runtime config
# ---------------------------------------------------------------------------
# Local bind of the core HTTP service (the reverse proxy targets this).
HOST=127.0.0.1
PORT=3020

# How the core reaches LiveKit (same host — see docker-compose host networking).
LIVEKIT_URL=ws://127.0.0.1:7880

# The ws/wss URL and RTMP host handed to browser clients & publishers in join
# links / tokens. On a real domain these ride the single TLS vhost via `/rtc`.
#   Real domain: PUBLIC_WS_URL=wss://streamhub.example.com  RTMP_PUBLIC_HOST=streamhub.example.com
#   Localhost:   PUBLIC_WS_URL=ws://127.0.0.1:7880          RTMP_PUBLIC_HOST=127.0.0.1
PUBLIC_WS_URL=wss://streamhub.example.com
RTMP_PUBLIC_HOST=streamhub.example.com

# Redis (used by LiveKit ingress/egress coordination AND BullMQ job queues).
REDIS_URL=redis://127.0.0.1:6379

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# Secret that signs the UI login JWT (POST /api/v1/auth/login).
STREAMHUB_JWT_SECRET=change-me-a-long-random-jwt-secret

# Break-glass admin login for the dashboard. Login is disabled if either is
# empty. On success the API returns a JWT signed with STREAMHUB_JWT_SECRET.
ADMIN_USER=admin
ADMIN_PASS=change-me-a-strong-admin-password

# Global API bearer token (sk_...) seeded into the DB by install.sh. This is the
# credential you pass as `Authorization: Bearer sk_...` to the REST API. It is
# stored here only so re-running install.sh stays idempotent; the DB keeps a hash.
STREAMHUB_API_TOKEN=sk_change_me

# Authorization + quota enforcement rollout: off | log | on.
# Fase-0 security: the CODE default (unset) is now `on` (secure-by-default), and
# fresh installs should keep `on`: RBAC is enforced, per-app `sk_` tokens are
# confined to their own app, and over-quota requests are rejected. `log` runs the
# same checks but only LOGS what they would block (use it to migrate an existing
# deployment that ran unenforced). GLOBAL `sk_` tokens and the break-glass admin
# always bypass RBAC — they are never locked out.
STREAMHUB_AUTHZ_ENFORCE=on

# ---------------------------------------------------------------------------
# Storage / data
# ---------------------------------------------------------------------------
# Path INSIDE the containers where the core (and egress) read/write data:
# data/streamhub.db, apps/<name>/{recordings,snapshots,hls,samples}, logs/, sdk/.
# Must be identical for `core` and `egress` (egress writes MP4s where core looks).
DATA_DIR=/data

# Path ON THE HOST that is bind-mounted to DATA_DIR in both containers.
STREAMHUB_HOST_DATA_DIR=./data

# ---------------------------------------------------------------------------
# Email (SMTP) — magic-link / invites (optional but recommended)
# ---------------------------------------------------------------------------
#STREAMHUB_SUPERADMIN_EMAIL=info@example.com

# Public self-signup ("Crear cuenta" in the dashboard + POST /auth/signup).
# UNSET/0 = invite-only (default): new emails get 403; invited pending users
# can still complete their signup. 1/true/on/yes = anyone can create an
# account + their own free-plan tenant. Surfaced to the SPA via GET /auth/config.
#STREAMHUB_ALLOW_SIGNUP=0
#STREAMHUB_SMTP_HOST=mail.example.com
#STREAMHUB_SMTP_PORT=587
#STREAMHUB_SMTP_USER=no-reply@example.com
#STREAMHUB_SMTP_PASS=change-me
#STREAMHUB_SMTP_FROM=StreamHub <no-reply@example.com>

# ---------------------------------------------------------------------------
# Observability / cluster
# ---------------------------------------------------------------------------
# Token that guards GET /metrics (Prometheus) on the core. Fase-0 default-deny:
# UNSET = /metrics returns 404 (disabled, never leaks). Set a token to enable
# scraping with `Authorization: Bearer <token>` (or `?token=`). The nginx/Caddy
# vhost ALSO denies /metrics from the outside — scrape locally at
# 127.0.0.1:3020/metrics.
#METRICS_TOKEN=mtk_change_me

# LiveKit's own services expose native Prometheus metrics on the HOST (compose
# uses network_mode: host). These are set in docker-compose.yml (prometheus_port)
# and are NOT env-tunable here; scrape them locally, keep the ports firewalled:
#   livekit-server 127.0.0.1:6789 · ingress :6790 · egress :6791

# Brute-force rate limiting for the SENSITIVE auth endpoints only (login,
# magic-link, magic/verify). The rest of the API — incl.
# the dashboard's background polling — is NOT limited. Per client IP, per window.
#AUTH_RATE_LIMIT_MAX=10           # max attempts per window (default 10)
#AUTH_RATE_LIMIT_WINDOW_MS=900000 # window in ms (default 900000 = 15 min)

# Shared secret that lets edge nodes register via POST /api/v1/cluster/join
# (install.sh --join sends it as X-Cluster-Token). Empty = joining disabled.
#STREAMHUB_CLUSTER_TOKEN=clt_change_me

# Redis URL handed to joining edges (defaults to redis://<--origin-ip>:6379 on
# the edge side if unset). Point it at a Redis reachable from the edges.
#STREAMHUB_CLUSTER_REDIS_URL=redis://10.0.0.1:6379

# Edge nodes only (written by install.sh --join): where livekit/ingress/egress
# find the CLUSTER redis (host:port [+ password]), and where LiveKit posts room
# webhooks (the ORIGIN's core — edges run no core). Origin/standalone: unset.
#LIVEKIT_REDIS_ADDRESS=10.0.0.1:6379
#LIVEKIT_REDIS_PASSWORD=change-me
#LIVEKIT_WEBHOOK_URL=https://media.example.com/api/v1/webhooks/livekit

# Origin with --cluster-redis-bind (install.sh): extra redis bind + auth so
# edges can reach it. REDIS_BIND takes several IPs space-separated.
#REDIS_BIND=127.0.0.1 10.0.0.1
#REDIS_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Resource limits (docker-compose, compose v2 non-swarm keys)
# ---------------------------------------------------------------------------
# Hard caps for the media services so one runaway session can't OOM the host.
# Defaults target an 8GB / 8-core box. EGRESS is the biggest risk: it drives a
# headless Chrome to composite rooms and its RAM grows with resolution/tracks.
#EGRESS_MEM_LIMIT=2g
#EGRESS_CPUS=2
#INGRESS_MEM_LIMIT=1g
#INGRESS_CPUS=1.5

# ---------------------------------------------------------------------------
# Backups (deploy/backup.sh — cron / systemd timer; see operations/BACKUPS.md)
# ---------------------------------------------------------------------------
# Host data dir to back up (streamhub.db + apps/<app>/app.db + secrets.json).
#BACKUP_DATA_DIR=/opt/streamhub/data
# Where local tarballs are kept (default <BACKUP_DATA_DIR>/backups).
#BACKUP_LOCAL_DIR=/opt/streamhub/data/backups
# Prune local + remote copies older than this many days.
#BACKUP_RETENTION_DAYS=30
# S3 (or S3-compatible) target. Leave BACKUP_S3_BUCKET empty for local-only.
#BACKUP_S3_BUCKET=my-streamhub-backups
#BACKUP_S3_ENDPOINT=https://s3.wasabisys.com   # omit for AWS S3
#BACKUP_S3_PREFIX=streamhub-backups
#BACKUP_S3_REGION=us-east-1
#BACKUP_S3_ACCESS_KEY_ID=change-me
#BACKUP_S3_SECRET_ACCESS_KEY=change-me

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
LOG_LEVEL=info
NODE_ENV=production
