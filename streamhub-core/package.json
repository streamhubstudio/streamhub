    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^8.0.0",
    "better-sqlite3": "^12.2.0",
    "bullmq": "^5.13.0",
    "casbin": "^5.51.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.1",
    "js-yaml": "^4.1.0",
    "livekit-server-sdk": "^2.7.0",
