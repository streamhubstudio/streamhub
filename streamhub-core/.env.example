# StreamHub core — env (do NOT commit the real .env). See STREAMHUB-SPEC.md §13.

# HTTP server
PORT=3020
HOST=127.0.0.1

# LiveKit (existing self-hosted instance)
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
PUBLIC_WS_URL=wss://media.example.com
RTMP_PUBLIC_HOST=media.example.com

# Redis (reused from LiveKit egress/ingress) — for BullMQ
REDIS_URL=redis://localhost:6379

# Auth — built-in user/password (StreamHub is the identity-of-record; no OIDC).
# Users self-serve via POST /api/v1/auth/signup and POST /api/v1/auth/login.
STREAMHUB_JWT_SECRET=change-me
# Break-glass SUPERADMIN credentials (POST /api/v1/auth/login). Optional but
# recommended: the platform owner that can never be locked out. Login for regular
# users still works if these are empty. On success the API returns a JWT signed
# with STREAMHUB_JWT_SECRET.
ADMIN_USER=admin
ADMIN_PASS=change-me-too

# Passwordless magic-link auth (Wave-7). Users sign in via
#   POST /api/v1/auth/magic-link { email }   → emails a one-time link
#   POST /api/v1/auth/magic/verify { token } → returns a session JWT
# STREAMHUB_APP_URL          Public SPA base URL the emailed link points at
#                            (…/auth/magic?token=<token>). Defaults to
#                            https://app.streamhub.studio.
# STREAMHUB_SUPERADMIN_EMAIL Email that, when it signs in via magic-link, is
#                            granted SUPERADMIN. Defaults to info@streamhub.studio.
STREAMHUB_APP_URL=https://app.streamhub.studio
STREAMHUB_SUPERADMIN_EMAIL=info@streamhub.studio

# SMTP for transactional email (nodemailer) — used by magic-link delivery.
# STREAMHUB_SMTP_PASS is a SECRET: set it only in the real .env (git-ignored),
# NEVER commit it. With no PASS, email is simply skipped (logged) and the app
# keeps running. Port 587 = STARTTLS (secure=false); 465 = implicit TLS.
STREAMHUB_SMTP_HOST=mail.wipermax.online
STREAMHUB_SMTP_PORT=587
STREAMHUB_SMTP_USER=no-reply@streamhub.studio
STREAMHUB_SMTP_PASS=
STREAMHUB_SMTP_FROM=StreamHub <no-reply@streamhub.studio>

# Storage / data dir. Holds data/streamhub.db, apps/<name>/..., logs/
DATA_DIR=/opt/streamhub

# Authorization + quotas enforcement (wave-5). Phased rollout:
#   off  = skip all RBAC/quota checks
#   log  = (DEFAULT) run checks but only LOG what they would block — deploying
#          does NOT change current behaviour
#   on   = enforce: owner/editor/viewer gated + over-quota rejected (403/429)
# isSuperadmin and api_token (sk_...) credentials ALWAYS bypass, in every mode.
STREAMHUB_AUTHZ_ENFORCE=log

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Observability (Prometheus) — see deploy/OBSERVABILITY.md
#   METRICS_TOKEN            optional bearer/`?token=` guard for GET /metrics.
#                            Empty = the endpoint is public (fine on a private net).
#   METRICS_DEFAULT_METRICS  set to `off` to disable process_*/nodejs_* metrics.
METRICS_TOKEN=
METRICS_DEFAULT_METRICS=on

# GPU hardware transcoding (optional) — see deploy/GPU.md
#   TRANSCODING_HWACCEL  global default hwaccel preference for apps that don't
#                        set their own: auto | gpu | cpu. 'auto' (default) uses
#                        the GPU when the node has one, else CPU. Per-app override
#                        via PATCH /api/v1/apps/:app/config { "hwaccel": "..." }.
#   GPU_DISABLE          set to `true` to hard-disable GPU detection (the node is
#                        reported as type:'none' and always transcodes on CPU).
# Detection is best-effort: with no NVIDIA driver / VAAPI device the feature just
# reports 'none' and everything runs on CPU (today's behaviour). GET the node's
# capability at /api/v1/system/gpu.
TRANSCODING_HWACCEL=auto
GPU_DISABLE=false
