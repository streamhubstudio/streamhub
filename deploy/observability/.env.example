# Variables de entorno para docker-compose.observability.yml.
# Copiar a deploy/observability/.env y completar (ese archivo queda
# gitignoreado por el patrón `**/.env` del .gitignore raíz — no lo commitees).
#
# Uso:
#   docker compose -f deploy/observability/docker-compose.observability.yml \
#     --env-file deploy/observability/.env up -d

# Obligatorio: password del usuario admin de Grafana. Sin default — el compose
# falla explícitamente si falta (evita quedar con admin/admin de la imagen).
GRAFANA_ADMIN_PASSWORD=__CHANGE_ME__

# Opcionales (tienen default razonable en el compose):
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ROOT_URL=http://127.0.0.1:3001/
# PROMETHEUS_RETENTION_TIME=15d
# PROMETHEUS_RETENTION_SIZE=4GB
