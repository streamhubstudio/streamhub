  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Nota de versión",
      "type": "text",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "Nombres de métricas LiveKit verificados contra la referencia oficial pero **varían entre versiones** — confirmar siempre contra el endpoint vivo (`curl 127.0.0.1:6789/metrics`). Requiere `prometheus_port` habilitado en livekit/ingress/egress (roadmap §4.3). Como base, considerar importar un dashboard community de LiveKit y recortarlo."
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "RTT p50/p95",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, direction) (rate(livekit_rtt_ms_bucket[5m])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "p50 {{direction}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, direction) (rate(livekit_rtt_ms_bucket[5m])))",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "p95 {{direction}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "title": "Forward latency p95",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(livekit_forward_latency_bucket[5m])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "title": "Packet loss (aprox.)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(livekit_packet_total{transmission=\"lost\"}[5m])) / sum(rate(livekit_packet_total[5m]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "title": "NACK / PLI (retransmisión)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 11,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (direction) (rate(livekit_nack_total[5m]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "nack {{direction}}"
        },
        {
          "expr": "sum by (direction) (rate(livekit_pli_total[5m]))",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "pli {{direction}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "title": "Rooms / duración de sesión",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "livekit_room_total",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "rooms"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(livekit_room_duration_seconds_bucket[5m])))",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "p95 duration"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 7,
      "title": "Participantes",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 19,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "livekit_participant_total",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 8,
      "title": "CPU / carga del nodo LiveKit",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "node_load1",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "load1"
        },
        {
          "expr": "node_load5",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "load5"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {},
      "description": "LiveKit expone su propio CpuLoad/MemoryUsed en versiones recientes; como proxy estable usamos node_exporter (mismo host, roadmap §5.C)."
    },
    {
      "id": 9,
      "title": "Egress / ingress activos",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 27,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "up{job=~\"livekit-egress|livekit-ingress\"}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "{{job}} up"
        },
        {
          "expr": "sum by (kind) (streamhub_media_sessions_active{kind=~\"egress|ingress\"})",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "{{kind}} sessions"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
