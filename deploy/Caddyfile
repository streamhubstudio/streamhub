# StreamHub — single-domain reverse proxy with automatic HTTPS.
#   /rtc*  -> LiveKit signaling (wss, WebRTC)   127.0.0.1:7880
#   /*     -> streamhub-core (NestJS: REST API + React SPA + HLS + /sdk)  127.0.0.1:3020
#
# STREAMHUB_SITE_ADDRESS / ACME_EMAIL are injected from the environment (see
# compose). It defaults to STREAMHUB_DOMAIN: a real hostname gets a Let's Encrypt
# cert automatically; `localhost` gets a local self-signed cert (browser warns —
# fine for testing). Under the installer's --no-tls (or an IP origin) it is set
# to `http://<domain-or-ip>`, which makes Caddy serve PLAIN HTTP (no cert).
# Media (UDP 7882) and RTMP (1935) bypass this proxy and hit the IP directly.

{
	email {$ACME_EMAIL}
}

{$STREAMHUB_SITE_ADDRESS:localhost} {
	encode zstd gzip
	request_body {
		max_size 50MB
	}

	# `handle` blocks are mutually exclusive and evaluated in order, so the
	# /metrics 403 always wins over the catch-all proxy below.

	# LiveKit WebRTC signaling (websocket upgrade handled automatically)
	@rtc path /rtc /rtc/*
	handle @rtc {
		reverse_proxy 127.0.0.1:7880
	}

	# /metrics is scraped locally on 127.0.0.1:3020 — never expose it externally.
	handle /metrics {
		respond 403
	}

	# Everything else: API + SPA + HLS + samples + /sdk
	handle {
		reverse_proxy 127.0.0.1:3020
	}
}
